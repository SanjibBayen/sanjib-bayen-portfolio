.cache/
.parcel-cache/
.eslintcache

# IDE

.idea/
*.iml

# VS Code

.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS Files

.DS_Store
Thumbs.db
desktop.ini

