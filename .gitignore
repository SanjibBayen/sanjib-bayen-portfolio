dist/
build/
out/
coverage/

# Vite

.vite/

# TypeScript

*.tsbuildinfo

# Environment Variables

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime

pids/
*.pid
*.seed
*.pid.lock

