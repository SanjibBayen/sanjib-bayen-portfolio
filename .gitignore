tmp/
temp/
*.tmp

# Local Database

*.sqlite
*.db

# Secrets & Keys

*.pem
*.key
*.crt
*.p12

# Deployment

.vercel
.netlify

# Generated Assets

generated/
screenshots/
exports/

# AI / Experimental

training_runs/
model_outputs/
checkpoints/

